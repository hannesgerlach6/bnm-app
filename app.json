{
  "expo": {
    "name": "BNM",
    "slug": "bnm-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/bnm-logo.png",
    "scheme": "bnmapp",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/189bfd5b-ec7f-447f-a625-99c0dcbec17b",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/images/bnm-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bnm.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "BNM benötigt Zugriff auf die Kamera für dein Profilbild.",
        "NSPhotoLibraryUsageDescription": "BNM benötigt Zugriff auf deine Fotos für dein Profilbild.",
        "NSPhotoLibraryAddUsageDescription": "BNM möchte Bilder in deiner Fotobibliothek speichern.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F9FAFB"
      },
      "package": "com.bnm.app",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "BNM",
      "shortName": "BNM",
      "description": "Mentoring-Programm für Konvertierte",
      "themeColor": "#0A3A5A",
      "backgroundColor": "#F9FAFB",
      "lang": "de"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0A3A5A"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-updates",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "189bfd5b-ec7f-447f-a625-99c0dcbec17b"
      }
    }
  }
}
