{
  "expo": {
    "name": "BNM",
    "slug": "bnm-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bnm-logo.png",
    "scheme": "bnmapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/bnm-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bnm.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/bnm-logo.png",
        "backgroundColor": "#F9FAFB"
      },
      "package": "com.bnm.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0A3A5A"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
