# Supabase – Client-seitig (öffentlich, RLS schützt die Daten)
EXPO_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT-ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Calendar OAuth (in Bundle eingebettet — nur für internes Tool akzeptabel)
# Werte: Google Cloud Console → APIs & Services → Credentials → BNM-App Google App
EXPO_PUBLIC_GOOGLE_CLIENT_ID=DEINE_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=GOCSPX-...

# Resend API-Key – NUR serverseitig (Supabase Secret, nie im Client!)
# Setzen via: supabase secrets set RESEND_API_KEY=re_...
# RESEND_API_KEY=re_...
